{
  "manifest_version": 2,
  "version": "0.1",
  "name": "Surgery Book",
  "short_name": "Book",
  "description": "A comprehensive surgery reference book",
  "icons": [{
    "src": "logoRama.jpg",
      "sizes": "256x256",
      "type": "image/jpg"
    }, {
    "src": "logoRama.jpg",
      "sizes": "128x128",
      "type": "image/jpg"
    }],
  "start_url": "index.php",
  "display": "standalone",
  "display_override": ["window-controls-overlay", "standalone"],
  "background_color": "#3E4EB8",
  "theme_color": "#2F3BA2",
  "orientation": "portrait-primary",
  "screenshots": [{
    "src": "logoRama.jpg",
    "sizes": "256x256",
    "type": "image/jpg"
  }],
  "shortcuts": [{
    "name": "Surgery Book",
    "short_name": "Book",
    "description": "Open Surgery Book",
    "url": "index.php",
    "icons": [{
      "src": "logoRama.jpg",
      "sizes": "256x256"
    }]
  }],
  "protocol_handlers": [{
    "protocol": "web+surgerybook",
    "url": "index.php?protocol=%s"
  }]
}
